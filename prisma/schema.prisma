generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("RECEPTIONIST") // SUPER_ADMIN, ADMIN, DOCTOR, ACCOUNTANT, RECEPTIONIST, PHARMACIST, PATHOLOGIST, RADIOLOGIST
  
  // New Staff Fields
  department String?
  shiftStart String?
  shiftEnd   String?
  contactInfo String?
  homeAddress String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  appointments Appointment[]
  prescriptions Prescription[]
  attendances Attendance[]
  dutyRosters DutyRoster[]
  leaveRequests LeaveRequest[]
  sentMessages Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  referralsMade Referral[]
}

model Patient {
  id             String       @id @default(cuid())
  patientId      String       @unique
  name           String
  age            Int
  gender         String
  diagnosis      String
  status         String       @default("monitoring")
  departmentName String?
  doctorName     String?
  allergies      String?
  bedId          String?      @unique
  
  // Phase 3 Additions
  dischargeEta       DateTime?
  isMediclaimSecure  Boolean   @default(false)
  advanceMoneyTaken  Float     @default(0)
  isAyushmanBharat   Boolean   @default(false)
  insuranceCompany   String?
  guardianName       String?
  guardianRelation   String?
  guardianPhone      String?
  guardianEmail      String?
  
  // Portal Security
  portalPin          String?   @default("1234")

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  bed            Bed?         @relation(fields: [bedId], references: [id])
  vitalSigns     VitalSign[]
  appointments   Appointment[]
  prescriptions  Prescription[]
  invoices       Invoice[]
  labTests       LabTest[]
  tpaClaims      TPAClaim[]
  referrals      Referral[]
}

model Bed {
  id             String   @id @default(cuid())
  label          String   @unique
  departmentName String
  floor          Int
  wing           String
  status         String   @default("available")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  patient        Patient?
}

model VitalSign {
  id          String   @id @default(cuid())
  patientId   String
  heartRate   Int
  bloodPress  String
  oxygenLevel Int
  temperature Float
  recordedAt  DateTime @default(now())

  patient     Patient  @relation(fields: [patientId], references: [id])
}

// === NEW PHASE 2 MODELS ===

model Appointment {
  id        String   @id @default(cuid())
  patientId String
  doctorId  String
  date      DateTime
  reason    String
  status    String   @default("scheduled") // scheduled, completed, cancelled
  isFollowUp Boolean @default(false)
  createdAt DateTime @default(now())

  patient   Patient  @relation(fields: [patientId], references: [id])
  doctor    User     @relation(fields: [doctorId], references: [id])
}

model Prescription {
  id             String   @id @default(cuid())
  patientId      String
  doctorId       String
  medicationName String
  dosage         String
  frequency      String
  duration       String
  status         String   @default("active") // active, completed
  createdAt      DateTime @default(now())

  patient        Patient  @relation(fields: [patientId], references: [id])
  doctor         User     @relation(fields: [doctorId], references: [id])
}

model InventoryItem {
  id               String   @id @default(cuid())
  itemName         String   @unique
  category         String   // Medicine, Equipment, Supply
  quantity         Int      @default(0)
  minimumThreshold Int      @default(10)
  lastRestocked    DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Invoice {
  id                  String   @id @default(cuid())
  patientId           String
  totalAmount         Float
  status              String   @default("pending") // pending, paid, overdue
  insuranceClaimStatus String? // none, submitted, approved, rejected
  dueDate             DateTime
  createdAt           DateTime @default(now())

  patient             Patient  @relation(fields: [patientId], references: [id])
}

// === NEW PHASE 4 MODELS ===

model LabTest {
  id          String   @id @default(cuid())
  patientId   String
  testName    String
  status      String   @default("pending") // pending, completed
  resultText  String?
  orderedBy   String?  // doctor user id
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient     Patient  @relation(fields: [patientId], references: [id])
}

model BloodBag {
  id          String   @id @default(cuid())
  bloodGroup  String   // A+, O-, etc.
  volumeMl    Int      @default(450)
  expiryDate  DateTime
  status      String   @default("available") // available, used, expired
  donatedAt   DateTime @default(now())
}

model Ambulance {
  id           String   @id @default(cuid())
  licensePlate String   @unique
  driverName   String
  phone        String
  type         String   @default("Basic Life Support")
  status       String   @default("available") // available, dispatched, arriving
  lastLocation String?
  updatedAt    DateTime @updatedAt
}

// === NEW PHASE 3 MODELS (HR & OPERATIONS) ===

model Attendance {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  clockIn   DateTime?
  clockOut  DateTime?
  status    String   @default("Present") // Present, Absent, Half-Day, On Leave
  workHours Float?
  notes     String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model DutyRoster {
  id         String   @id @default(cuid())
  userId     String
  shiftName  String   // Morning, Evening, Night
  department String
  wardOrFloor String?
  date       DateTime
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
}

model LeaveRequest {
  id         String   @id @default(cuid())
  userId     String
  leaveType  String   // Sick, Casual, Paid
  startDate  DateTime
  endDate    DateTime
  reason     String
  status     String   @default("Pending") // Pending, Approved, Rejected
  appliedAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id])
}

model FrontOfficeVisitor {
  id           String   @id @default(cuid())
  visitorName  String
  phone        String
  purpose      String
  whomToMeet   String
  checkInTime  DateTime @default(now())
  checkOutTime DateTime?
  status       String   @default("Active") // Active, Checked-Out
}

// === NEW PHASE 4 MODELS (EXTENDED ENTERPRISE) ===

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  isRead     Boolean  @default(false)
  timestamp  DateTime @default(now())

  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

model TPAClaim {
  id               String   @id @default(cuid())
  patientId        String
  insuranceCompany String
  policyNumber     String
  claimAmount      Float
  status           String   @default("Pending") // Pending, Approved, Rejected
  submittedAt      DateTime @default(now())
  updatedAt        DateTime @updatedAt

  patient          Patient  @relation(fields: [patientId], references: [id])
}

model Referral {
  id          String   @id @default(cuid())
  patientId   String
  referredBy  String   // User ID
  referredTo  String   // External Doctor / Hospital
  reason      String
  status      String   @default("Pending")
  date        DateTime @default(now())

  patient     Patient  @relation(fields: [patientId], references: [id])
  doctor      User     @relation(fields: [referredBy], references: [id])
}

// === NEW PHASE 5 MODELS ===

model Branch {
  id          String   @id @default(cuid())
  name        String
  location    String
  contactNum  String
  head        String?
  createdAt   DateTime @default(now())
}

model Certificate {
  id          String   @id @default(cuid())
  patientName String
  type        String   // Birth, Death, Medical, Discharge
  issueDate   DateTime @default(now())
  issuedBy    String   // Doctor/Staff Name
  notes       String?
}

model LiveConsultation {
  id          String   @id @default(cuid())
  patientName String
  doctorName  String
  date        DateTime
  meetingLink String
  status      String   @default("Scheduled") // Scheduled, Completed, Cancelled
  createdAt   DateTime @default(now())
}

model Document {
  id          String   @id @default(cuid())
  title       String
  type        String   // PDF, DOCX, etc.
  url         String
  uploadedBy  String   // Staff Name
  uploadedAt  DateTime @default(now())
}

model BirthRecord {
  id          String   @id @default(cuid())
  childName   String
  gender      String
  weight      Float
  birthDate   DateTime
  motherName  String
  fatherName  String
  doctorName  String
  createdAt   DateTime @default(now())
}

model DeathRecord {
  id          String   @id @default(cuid())
  patientName String
  age         Int
  gender      String
  deathDate   DateTime
  cause       String
  doctorName  String
  createdAt   DateTime @default(now())
}
